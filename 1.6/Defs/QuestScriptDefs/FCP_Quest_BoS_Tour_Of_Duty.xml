<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <QuestScriptDef>
        <defName>FCP_Quest_BoS_Tour_Of_Duty</defName>
        <rootSelectionWeight>1.0</rootSelectionWeight>
        <rootMinPoints>150</rootMinPoints>
        <defaultChallengeRating>2</defaultChallengeRating>
        <canGiveRoyalFavor>true</canGiveRoyalFavor>
        <expireDaysRange>5~10</expireDaysRange>
        <questNameRules>
            <rulesStrings>
                <li>questName->Tour of Duty</li>
                <li>questName->Danse's Assignment</li>
                <li>questName->Paladin's Errand</li>
                <li>questName->A Soldier's Duty</li>
                <li>questName->Attaching to Paladin Danse</li>
            </rulesStrings>
        </questNameRules>
        <questDescriptionRules>
            <rulesStrings>
                <li>requirements->Requirements: escort Paladin Danse to the cache and keep him alive while it's cleared. If he dies, the mission fails even if the cache is secured.</li>
                <li>questDescription->Elder Maxson is sending Paladin Danse to secure a pre-war tech cache before scavengers strip it bare. [asker_nameFull] wants outside guns attached to the detail - Danse is a fine soldier, but one soldier alone against however many raiders are squatting on that cache is bad math.\n\n[requirements]</li>
                <li>questDescription->[asker_nameFull]: "Paladin Danse is heading out to secure a cache before it's lost. He won't ask for help, so I'm assigning some. Keep him alive and get that tech back to the Prydwen."\n\n[requirements]</li>
                <li>questDescription->A pre-war tech cache has raiders camped on top of it, and Elder Maxson wants it in Brotherhood hands. [asker_nameFull] is sending Paladin Danse to lead the recovery - attach yourselves to his detail and see it through.\n\n[requirements]</li>
                <li>questDescription->[asker_nameFull] speaks well of Paladin Danse - dependable, thorough, exactly who you want leading a recovery under fire. Escort him to the cache, clear whoever's holding it, and get him home.\n\n[requirements]</li>
            </rulesStrings>
        </questDescriptionRules>
        <root Class="QuestNode_Sequence">
            <nodes>
                <li Class="QuestNode_SubScript">
                    <def>Util_RandomizePointsChallengeRating</def>
                    <parms>
                        <pointsFactorTwoStar>1.3</pointsFactorTwoStar>
                        <pointsFactorThreeStar>1.7</pointsFactorThreeStar>
                    </parms>
                </li>
                <li Class="QuestNode_SubScript">
                    <def>Util_AdjustPointsForDistantFight</def>
                </li>
                <li Class="QuestNode_GetMap" />
                <li Class="FCP.Core.RadiantQuests.QuestNode_GetFactionFromList">
                    <storeAs>askerFaction</storeAs>
                    <factionDefs>
                        <li>FCP_Faction_BoS</li>
                    </factionDefs>
                </li>
                <li Class="FCP.Core.RadiantQuests.QuestNode_GetLeaderOfFaction">
                    <storeAs>asker</storeAs>
                    <factionToUse>$askerFaction</factionToUse>
                </li>
                <li Class="FCP.Core.RadiantQuests.QuestNode_GenerateUniqueCharacterPawn">
                    <characterDef>FCP_Character_BoS_Paladin_Danse</characterDef>
                    <addToList>danse</addToList>
                </li>
                <li Class="QuestNode_SetAllApparelLocked">
                    <pawns>$danse</pawns>
                </li>
                <li Class="QuestNode_JoinPlayer">
                    <pawns>$danse</pawns>
                    <joinPlayer>true</joinPlayer>
                </li>
                <li Class="QuestNode_ExtraFaction">
                    <factionOf>$asker</factionOf>
                    <pawns>$danse</pawns>
                    <factionType>HomeFaction</factionType>
                    <inSignalsRemovePawn>
                        <li>danse.RanWild</li>
                    </inSignalsRemovePawn>
                </li>
                <li Class="QuestNode_GetSiteTile">
                    <storeAs>siteTile</storeAs>
                    <preferCloserTiles>true</preferCloserTiles>
                </li>
                <li Class="QuestNode_GetSitePartDefsByTagsAndFaction">
                    <storeAs>sitePartDefs</storeAs>
                    <storeFactionAs>siteFaction</storeFactionAs>
                    <sitePartsTags>
                        <li>
                            <tag>FCP_Site_BoS_Tech_Cache</tag>
                        </li>
                    </sitePartsTags>
                    <mustBeHostileToFactionOf>$asker</mustBeHostileToFactionOf>
                </li>
                <li Class="QuestNode_GetDefaultSitePartsParams">
                    <tile>$siteTile</tile>
                    <faction>$siteFaction</faction>
                    <sitePartDefs>$sitePartDefs</sitePartDefs>
                    <storeSitePartsParamsAs>sitePartsParams</storeSitePartsParamsAs>
                </li>
                <li Class="QuestNode_SubScript">
                    <def>Util_GenerateSite</def>
                    <parms>
                        <hiddenSitePartsPossible>true</hiddenSitePartsPossible>
                    </parms>
                </li>
                <li Class="FCP.Core.RadiantQuests.QuestNode_SpawnPawns">
                    <inSignal>site.MapGenerated</inSignal>
                    <pawns>$danse</pawns>
                    <mapParent>$site</mapParent>
                </li>
                <li Class="QuestNode_LeaveOnCleanup">
                    <pawns>$danse</pawns>
                    <sendStandardLetter>false</sendStandardLetter>
                </li>
                <li Class="QuestNode_SpawnWorldObjects">
                    <worldObjects>$site</worldObjects>
                    <defsToExcludeFromHyperlinks>Human</defsToExcludeFromHyperlinks>
                </li>
                <li Class="QuestNode_WorldObjectTimeout">
                    <worldObject>$site</worldObject>
                    <isQuestTimeout>true</isQuestTimeout>
                    <delayTicks>$(randInt(12,24)*60000)</delayTicks>
                    <inSignalDisable>site.MapGenerated</inSignalDisable>
                    <node Class="QuestNode_Sequence">
                        <nodes>
                            <li Class="QuestNode_Letter">
                                <label>Cache lost</label>
                                <text>The raiders finished stripping the cache and moved on before Danse's detail arrived. Elder Maxson is not pleased.</text>
                            </li>
                            <li Class="QuestNode_End">
                                <outcome>Fail</outcome>
                                <goodwillChangeAmount>-5</goodwillChangeAmount>
                                <goodwillChangeFactionOf>$asker</goodwillChangeFactionOf>
                            </li>
                        </nodes>
                    </node>
                </li>
                <li Class="QuestNode_Signal">
                    <inSignal>site.AllEnemiesDefeated</inSignal>
                    <node Class="QuestNode_Sequence">
                        <nodes>
                            <li Class="QuestNode_AnyPawnAlive">
                                <pawns>$danse</pawns>
                                <node Class="QuestNode_Sequence">
                                    <nodes>
                                        <li Class="QuestNode_Letter">
                                            <letterDef>PositiveEvent</letterDef>
                                            <label>Cache secured</label>
                                            <text>The raiders are dead and Paladin Danse has the cache logged and ready for transport. His report to Elder Maxson will mention you by name.</text>
                                        </li>
                                        <li Class="QuestNode_GiveRewards">
                                            <parms>
                                                <allowGoodwill>true</allowGoodwill>
                                                <allowRoyalFavor>true</allowRoyalFavor>
                                            </parms>
                                            <addCampLootReward>true</addCampLootReward>
                                            <customLetterLabel>Payment from the Brotherhood</customLetterLabel>
                                            <customLetterText>The Prydwen sends payment for a job Paladin Danse says was done right.</customLetterText>
                                        </li>
                                        <li Class="QuestNode_End">
                                            <outcome>Success</outcome>
                                        </li>
                                    </nodes>
                                </node>
                            </li>
                            <li Class="QuestNode_Letter">
                                <label>Danse lost</label>
                                <letterDef>NegativeEvent</letterDef>
                                <text>The cache is clear, but Paladin Danse didn't survive taking it. Elder Maxson will want to know how one of his best paladins died on an escorted recovery.</text>
                            </li>
                            <li Class="QuestNode_End">
                                <outcome>Fail</outcome>
                                <goodwillChangeAmount>-10</goodwillChangeAmount>
                                <goodwillChangeFactionOf>$asker</goodwillChangeFactionOf>
                            </li>
                        </nodes>
                    </node>
                </li>
                <li Class="QuestNode_Signal">
                    <inSignal>site.Destroyed</inSignal>
                    <node Class="QuestNode_Sequence">
                        <nodes>
                            <li Class="QuestNode_Letter">
                                <label>quest failed: [resolvedQuestName]</label>
                                <text>The cache site was abandoned before it could be cleared. Quest [resolvedQuestName] ended.</text>
                            </li>
                            <li Class="QuestNode_End">
                                <outcome>Fail</outcome>
                            </li>
                        </nodes>
                    </node>
                </li>
            </nodes>
        </root>
    </QuestScriptDef>

</Defs>
