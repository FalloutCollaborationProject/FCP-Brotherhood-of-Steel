<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <!-- Upgrade Reinforced Combat Armor to BoS Reinforced Combat Armor -->
    <RecipeDef MayRequire="Rick.FCP.Wastelanders">
        <defName>FCP_Paint_Apparel_BoS_Classic_Combat_Armor_Reinforced</defName>
        <label>upgrade reinforced combat armor (BoS)</label>
        <description>Upgrade reinforced combat armor with Brotherhood of Steel technology and specialized components.</description>
        <jobString>Upgrading armor.</jobString>
        <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
        <effectWorking>Smith</effectWorking>
        <soundWorking>Recipe_Tailor</soundWorking>
        <workAmount>1000</workAmount>
        <workSkill>Crafting</workSkill>
        <researchPrerequisite>FCP_Research_BoS_Specialized_Armor</researchPrerequisite>
        <skillRequirements>
            <Crafting>8</Crafting>
        </skillRequirements>
        <ingredients>
            <li>
                <filter>
                    <thingDefs>
                        <li MayRequire="Rick.FCP.Wastelanders">FCP_Apparel_Reinforced_Combat_Armor</li>
                    </thingDefs>
                </filter>
                <count>1</count>
            </li>
        </ingredients>
        <products>
            <FCP_Apparel_BoS_Classic_Combat_Armor_Reinforced>1</FCP_Apparel_BoS_Classic_Combat_Armor_Reinforced>
        </products>
        <recipeUsers>
            <li>FCP_Production_Armor_Workbench</li>
        </recipeUsers>
    </RecipeDef>

